# Example environment variables for the HAKEY backend
# Copy this file to `.env` and update the values before running the server.

# MySQL / MariaDB connection settings
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=hakey_db

# Server port
PORT=4000

# Optional: if you use a different host (e.g., docker, remote DB), update DB_HOST and DB_PASSWORD accordingly.

# NOTES:
# - After creating `.env` with the correct DB credentials, run `npm install` (already done) and then
#   `node index.js` (or `npm run dev` if you have nodemon) to start the backend.
